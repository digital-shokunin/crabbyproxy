FROM rust:slim-bookworm

RUN apt-get update && apt-get install -y --no-install-recommends \
    pkg-config libssl-dev ca-certificates && rm -rf /var/lib/apt/lists/*

WORKDIR /src
COPY . .

# Simulate Homebrew prefix layout
ENV HOMEBREW_PREFIX=/opt/homebrew
RUN mkdir -p ${HOMEBREW_PREFIX}/bin ${HOMEBREW_PREFIX}/etc/crabbyproxy ${HOMEBREW_PREFIX}/var/log

# Step 1: cargo install (what `brew install` runs)
RUN cargo install --locked --root ${HOMEBREW_PREFIX} --path . \
    && echo "PASS: cargo install"

# Step 2: install config files (formula install block)
RUN cp proxy.pac ${HOMEBREW_PREFIX}/etc/crabbyproxy/proxy.pac \
    && cp doh.conf.default ${HOMEBREW_PREFIX}/etc/crabbyproxy/doh.conf \
    && cp crabbyproxy-setpac ${HOMEBREW_PREFIX}/bin/crabbyproxy-setpac \
    && chmod 755 ${HOMEBREW_PREFIX}/bin/crabbyproxy-setpac \
    && echo "PASS: config files installed"

# Step 3: post_install — copy to ~/.config/crabbyproxy if not present
RUN mkdir -p /root/.config/crabbyproxy \
    && cp ${HOMEBREW_PREFIX}/etc/crabbyproxy/proxy.pac /root/.config/crabbyproxy/proxy.pac \
    && cp ${HOMEBREW_PREFIX}/etc/crabbyproxy/doh.conf /root/.config/crabbyproxy/doh.conf \
    && echo "PASS: post_install config copy"

# Step 4: verify binary and all expected files
RUN test -x ${HOMEBREW_PREFIX}/bin/crabbyproxy && echo "PASS: binary present"
RUN test -f ${HOMEBREW_PREFIX}/etc/crabbyproxy/proxy.pac && echo "PASS: pac in etc"
RUN test -f ${HOMEBREW_PREFIX}/etc/crabbyproxy/doh.conf && echo "PASS: doh in etc"
RUN test -f ${HOMEBREW_PREFIX}/bin/crabbyproxy-setpac && echo "PASS: setpac helper present"
RUN test -f /root/.config/crabbyproxy/proxy.pac && echo "PASS: pac in user config"
RUN test -f /root/.config/crabbyproxy/doh.conf && echo "PASS: doh in user config"

# Step 5: binary starts and logs expected output (macOS features unavailable but startup should succeed)
RUN timeout 3 ${HOMEBREW_PREFIX}/bin/crabbyproxy 2>&1 | tee /tmp/startup.log || true \
    && grep -q "SOCKS5" /tmp/startup.log && echo "PASS: binary starts" \
    && grep -q "PAC server" /tmp/startup.log && echo "PASS: PAC server spawned"
